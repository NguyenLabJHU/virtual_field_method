	<MeshDomains>
		<SolidDomain name="Part1" mat="Matrix"/>
		<SolidDomain name="Part2" mat="Inclusion"/>
		<SolidDomain name="Part3" mat="Matrix"/>
		<SolidDomain name="Part4" mat="Matrix"/>
		<SolidDomain name="Part5" mat="Matrix"/>
		<SolidDomain name="Part6" mat="Inclusion"/>
		<SolidDomain name="Part7" mat="Inclusion"/>
		<SolidDomain name="Part8" mat="Inclusion"/>
	</MeshDomains>
	<Step>
		<step id="1" name="Step01">
			<Control>
				<analysis>STATIC</analysis>
				<time_steps>15</time_steps>
				<step_size>0.1</step_size>
				<plot_zero_state>1</plot_zero_state>
				<plot_range>0,-1</plot_range>
				<plot_level>PLOT_MAJOR_ITRS</plot_level>
				<output_level>OUTPUT_MAJOR_ITRS</output_level>
				<plot_stride>1</plot_stride>
				<output_stride>1</output_stride>
				<adaptor_re_solve>1</adaptor_re_solve>
				<time_stepper type="default">
					<max_retries>10</max_retries>
					<opt_iter>50</opt_iter>
					<dtmin>0.0001</dtmin>
					<dtmax lc="2">4</dtmax>
					<aggressiveness>1</aggressiveness>
					<cutback>0.5</cutback>
					<dtforce>0</dtforce>
				</time_stepper>
				<solver type="solid">
					<symmetric_stiffness>non-symmetric</symmetric_stiffness>
					<equation_scheme>staggered</equation_scheme>
					<equation_order>default</equation_order>
					<optimize_bw>0</optimize_bw>
					<lstol>0.5</lstol>
					<lsmin>0.01</lsmin>
					<lsiter>5</lsiter>
					<ls_check_jacobians>0</ls_check_jacobians>
					<max_refs>50</max_refs>
					<check_zero_diagonal>0</check_zero_diagonal>
					<zero_diagonal_tol>0</zero_diagonal_tol>
					<force_partition>0</force_partition>
					<reform_each_time_step>1</reform_each_time_step>
					<reform_augment>0</reform_augment>
					<diverge_reform>1</diverge_reform>
					<min_residual>1e-20</min_residual>
					<max_residual>10</max_residual>
					<dtol>1e-16</dtol>
					<etol>1e-16</etol>
					<rtol>1e-16</rtol>
					<rhoi>-2</rhoi>
					<alpha>1</alpha>
					<beta>0.25</beta>
					<gamma>0.5</gamma>
					<logSolve>0</logSolve>
					<arc_length>0</arc_length>
					<arc_length_scale>0</arc_length_scale>
					<qn_method type="Broyden">
						<max_ups>10</max_ups>
						<max_buffer_size>0</max_buffer_size>
						<cycle_buffer>1</cycle_buffer>
						<cmax>100000</cmax>
					</qn_method>
				</solver>
			</Control>
			<Boundary>
				<bc name="ZeroDisplacement_Z" node_set="@surface:ZeroDisplacement_Z" type="zero displacement">
					<x_dof>0</x_dof>
					<y_dof>0</y_dof>
					<z_dof>1</z_dof>
				</bc>
				<bc name="ZeroDisplacement_Y" node_set="@surface:ZeroDisplacement_Y" type="zero displacement">
					<x_dof>0</x_dof>
					<y_dof>1</y_dof>
					<z_dof>0</z_dof>
				</bc>
				<bc name="ZeroDisplacement_X" node_set="@surface:ZeroDisplacement_X" type="zero displacement">
					<x_dof>1</x_dof>
					<y_dof>0</y_dof>
					<z_dof>0</z_dof>
				</bc>
			</Boundary>
			<Loads>
				<surface_load name="Pressure1" surface="Pressure1" type="pressure">
					<pressure lc="3">-1</pressure>
					<symmetric_stiffness>0</symmetric_stiffness>
					<linear>0</linear>
					<shell_bottom>0</shell_bottom>
				</surface_load>
			</Loads>
		</step>
	</Step>
	<LoadData>
		<load_controller id="1" name="LC1" type="loadcurve">
			<interpolate>STEP</interpolate>
			<extend>CONSTANT</extend>
			<points>
				<pt>1,1</pt>
				<pt>2,0</pt>
			</points>
		</load_controller>
		<load_controller id="2" name="LC2" type="loadcurve">
			<interpolate>STEP</interpolate>
			<extend>CONSTANT</extend>
			<points>
				<pt>0,0.1</pt>
				<pt>0.9998,0.1</pt>
				<pt>1,0.0001</pt>
				<pt>2,0.1</pt>
			</points>
		</load_controller>
		<load_controller id="3" name="LC3" type="loadcurve">
			<interpolate>LINEAR</interpolate>
			<extend>CONSTANT</extend>
			<points>
				<pt>0,0</pt>
				<pt>1,0.03</pt>
				<pt>1.5,0.15</pt>
				<pt>2,0</pt>
			</points>
		</load_controller>
	</LoadData>
	<Output>
		<plotfile type="febio">
			<var type="displacement"/>
			<var type="stress"/>
			<var type="relative volume"/>
			<var type="nodal stress"/>
			<var type="Lagrange strain"/>
			<var type="reaction forces"/>
			<var type="deformation gradient"/>
		</plotfile>
		<logfile>
			<node_data data="x;y;z;ux;uy;uz"/>
			<element_data data="sx;sy;sz;sxz;syz;sxy"/>
			<element_data data="Fxx;Fxy;Fxz;Fyx;Fyy;Fyz;Fzx;Fzy;Fzz;Gxx;Gxy;Gxz;Gyx;Gyy;Gyz;Gzx;Gzy;Gzz"/>
		</logfile>
	</Output>
</febio_spec>
